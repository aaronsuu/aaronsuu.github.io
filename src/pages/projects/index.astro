---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));

const FLAG_LABEL = {
  'claude-assisted': 'Claude-Assisted',
  'claude-researched': 'Claude-Researched',
  'independent': 'Independent',
} as const;
---

<BaseLayout title="Projects — Aaron Su">
  <section class="proj-h mx">
    <h1>All <em>Projects</em></h1>
    <p>Everything I've worked on. Use the search bar to filter by keyword or technology.</p>
    <div class="flag-legend" aria-label="AI involvement legend">
      <span class="fl-item"><span class="flag flag-claude-assisted"><span class="fdot"></span>Claude-Assisted</span> Claude paired on code.</span>
      <span class="fl-item"><span class="flag flag-claude-researched"><span class="fdot"></span>Claude-Researched</span> Claude helped explore concepts; code is mine.</span>
      <span class="fl-item"><span class="flag flag-independent"><span class="fdot"></span>Independent</span> No AI involvement.</span>
    </div>
  </section>
  <section class="gal mx">
    <div class="gg" id="gg">
      {projects.map((p, i) => {
        const allKw = [...p.data.keywords, ...(p.data.minorTags ?? [])];
        return (
          <a
            class="card"
            href={`/projects/${p.id}`}
            data-title={p.data.title.toLowerCase()}
            data-desc={p.data.description.toLowerCase()}
            data-keywords={allKw.map(k => k.toLowerCase()).join('|')}
            data-flag={p.data.flag}
            style={`animation-delay:${(i + 1) * 0.06}s`}
          >
            <div class="card-th">
              {p.data.coverHtml
                ? <iframe class="card-iframe" src={p.data.coverHtml} title={p.data.title} loading="lazy" tabindex="-1" aria-hidden="true"></iframe>
                : p.data.thumbnail
                  ? <img src={p.data.thumbnail} alt={p.data.title} loading="lazy" />
                  : <span class="phi">⬡</span>}
              <span class={`flag flag-${p.data.flag} card-flag`} title={FLAG_LABEL[p.data.flag]}>
                <span class="fdot"></span>{FLAG_LABEL[p.data.flag]}
              </span>
            </div>
            <div class="card-b">
              <h3 class="card-t">{p.data.title}</h3>
              <p class="card-d">{p.data.description}</p>
              <div class="tags">
                {p.data.keywords.map(k => <span class="tg" data-kw={k.toLowerCase()}>{k}</span>)}
              </div>
            </div>
          </a>
        );
      })}
    </div>
    <div class="empty" id="emp">
      <svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="20" cy="20" r="14"/><line x1="30" y1="30" x2="44" y2="44"/></svg>
      <h3>No projects found</h3>
      <p>Try a different keyword or clear the search.</p>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  (function () {
    var si = document.getElementById('si');
    var sx = document.getElementById('sx');
    var rc = document.getElementById('rc');
    var emp = document.getElementById('emp');
    var cards = Array.prototype.slice.call(document.querySelectorAll('.card'));
    if (!si) return;

    function apply(q) {
      q = (q || '').toLowerCase().trim();
      var shown = 0;
      cards.forEach(function (c) {
        var t = c.getAttribute('data-title') || '';
        var d = c.getAttribute('data-desc') || '';
        var kws = (c.getAttribute('data-keywords') || '').split('|');
        var m = !q || t.indexOf(q) > -1 || d.indexOf(q) > -1 || kws.some(function (k) { return k.indexOf(q) > -1; });
        c.style.display = m ? '' : 'none';
        if (m) shown++;
        Array.prototype.forEach.call(c.querySelectorAll('.tg'), function (tg) {
          var kw = tg.getAttribute('data-kw') || '';
          tg.classList.toggle('match', !!q && kw.indexOf(q) > -1);
        });
      });
      emp.classList.toggle('vis', shown === 0);
      if (rc) rc.textContent = q ? shown + ' result' + (shown !== 1 ? 's' : '') : '';
      if (sx) sx.classList.toggle('vis', si.value.length > 0);
    }

    si.addEventListener('input', function () { apply(si.value); });
    if (sx) sx.addEventListener('click', function () { si.value = ''; apply(''); si.focus(); });
    apply('');
  })();
</script>
