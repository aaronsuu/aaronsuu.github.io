    <p>Browse my projects, filtered by technology or keyword.</p>
    <a class="cta-btn" href="/projects">View Projects <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="4" y1="9" x2="14" y2="9"/><polyline points="10,5 14,9 10,13"/></svg></a>
  </section>
</BaseLayout>

<script is:inline>
  (function () {
    var TITLES = ["Machine Learning Engineer","Computer Vision Engineer","Electrical Engineer","Software Developer","Embedded Systems Engineer","Licensed Paramedic","Caffeine-Powered Problem Solver"];
    var el = document.getElementById('tw');
    if (!el) return;
    var ti = 0, ci = 0, del = false;
    function t() {
      var cur = TITLES[ti];
      if (!del) {
        el.textContent = cur.substring(0, ci + 1);
        ci++;
        if (ci === cur.length) { del = true; setTimeout(t, 2000); return; }
        setTimeout(t, 70);
      } else {
        el.textContent = cur.substring(0, ci - 1);
        ci--;
        if (ci === 0) { del = false; ti = (ti + 1) % TITLES.length; setTimeout(t, 400); return; }
        setTimeout(t, 40);
      }
    }
    setTimeout(t, 600);
  })();
</script>
