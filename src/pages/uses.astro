---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Uses — Aaron Su">
  <section class="uses-w">
    <h1>What I <em>Use</em></h1>
    <p>The tools, hardware, and software that power my day-to-day. Inspired by <a href="https://uses.tech" target="_blank">uses.tech</a>.</p>

    <div class="ucat">
      <div class="ucat-t">Hardware</div>
      <div class="uitm"><span class="uitm-n">Laptop</span><span class="uitm-d">Your laptop model here</span></div>
      <div class="uitm"><span class="uitm-n">Monitor</span><span class="uitm-d">Your monitor here</span></div>
      <div class="uitm"><span class="uitm-n">Keyboard</span><span class="uitm-d">Your keyboard here</span></div>
      <div class="uitm"><span class="uitm-n">Mouse</span><span class="uitm-d">Your mouse here</span></div>
      <div class="uitm"><span class="uitm-n">Headphones</span><span class="uitm-d">Your headphones here</span></div>
    </div>

    <div class="ucat">
      <div class="ucat-t">Software &amp; Tools</div>
      <div class="uitm"><span class="uitm-n">Editor / IDE</span><span class="uitm-d">e.g. VS Code, PyCharm</span></div>
      <div class="uitm"><span class="uitm-n">Terminal</span><span class="uitm-d">e.g. iTerm2, Windows Terminal</span></div>
      <div class="uitm"><span class="uitm-n">Design</span><span class="uitm-d">e.g. Figma, Fusion 360</span></div>
      <div class="uitm"><span class="uitm-n">Notes</span><span class="uitm-d">e.g. Notion, Obsidian</span></div>
      <div class="uitm"><span class="uitm-n">Browser</span><span class="uitm-d">e.g. Arc, Chrome</span></div>
    </div>

    <div class="ucat">
      <div class="ucat-t">Desk &amp; Everyday Carry</div>
      <div class="uitm"><span class="uitm-n">Desk</span><span class="uitm-d">Your desk setup here</span></div>
      <div class="uitm"><span class="uitm-n">Chair</span><span class="uitm-d">Your chair here</span></div>
      <div class="uitm"><span class="uitm-n">Coffee</span><span class="uitm-d">Your go-to order</span></div>
    </div>

    <div class="ucat">
      <div class="ucat-t">Lab &amp; Maker Gear</div>
      <div class="uitm"><span class="uitm-n">Soldering Iron</span><span class="uitm-d">Your model here</span></div>
      <div class="uitm"><span class="uitm-n">Oscilloscope</span><span class="uitm-d">Your model here</span></div>
      <div class="uitm"><span class="uitm-n">3D Printer</span><span class="uitm-d">Your model here</span></div>
      <div class="uitm"><span class="uitm-n">Microcontrollers</span><span class="uitm-d">e.g. ESP32, Arduino</span></div>
    </div>
  </section>
</BaseLayout>
